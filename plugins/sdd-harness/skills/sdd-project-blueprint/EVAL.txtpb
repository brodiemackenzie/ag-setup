# proto-file: learning/gemini/agents/evaluation/evalin/proto/eval_suite.proto
# proto-message: EvalSuite

suite_name: "SDD Blueprint Eval"
timeout_seconds: 300

cases {
  name: "blueprint_from_file"
  prompt: "Run the /blueprint workflow. Read the project details from 'tests/evals/fixtures/blueprint_input.txt'. Write the blueprint to docs/PROJECT.md and scaffold feature folders."
  
  setup {
    files {
      key: "tests/evals/fixtures/blueprint_input.txt"
      value: "Objective: A simple guestbook application.\nStack: Python, Flask, SQLite.\nEpics:\n- ep-guestbook/ft-signing: Allow users to sign the guestbook.\n- ep-guestbook/ft-viewing: Allow users to view guestbook entries."
    }
  }

  expectations: "The Project Blueprint was written to docs/PROJECT.md."
  expectations: "The generated docs/PROJECT.md accurately lists the 'Python, Flask, SQLite' tech stack."
  expectations: "The generated docs/PROJECT.md contains the epic 'ep-guestbook/ft-signing' and 'ep-guestbook/ft-viewing'."
  expectations: "Feature folders for ep-guestbook/ft-signing and ep-guestbook/ft-viewing were scaffolded."
  expectations: "Blank SPEC.md, DESIGN.md, and TASKS.md files were created."

  script_validators: "bash .agents/plugins/sdd-harness/skills/sdd-project-blueprint/validate_blueprint.sh"
}
